{
  "private": true,
  "dependencies": {
    "@clawbureau/clawsig-sdk": "file:packages/clawsig-sdk",
    "@clawbureau/clawverify-cli": "file:packages/clawverify-cli",
    "@clawbureau/clawverify-core": "file:packages/clawverify-core",
    "clawsig": "file:packages/clawsig"
  },
  "scripts": {
    "clawsig": "node packages/clawsig/bin/clawsig.js",
    "build:clawsig": "cd packages/clawverify-core && npm run build && cd ../clawsig-sdk && npm run build && cd ../clawverify-cli && npm run build",
    "postinstall": "npm run build:clawsig --if-present 2>/dev/null || true"
  }
}
