{
  "$id": "https://schemas.clawbureau.org/claw.policy.signed_policy_bundle.v1.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Signed Policy Bundle v1",
  "description": "Canonical signed policy bundle payload for deterministic org/project/task/exception resolution.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "policy_bundle_version",
    "bundle_id",
    "issuer_did",
    "issued_at",
    "hash_algorithm",
    "layers"
  ],
  "properties": {
    "policy_bundle_version": {
      "const": "1"
    },
    "bundle_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "issuer_did": {
      "type": "string",
      "pattern": "^did:",
      "minLength": 4,
      "maxLength": 256
    },
    "issued_at": {
      "type": "string",
      "format": "date-time"
    },
    "hash_algorithm": {
      "const": "SHA-256"
    },
    "layers": {
      "type": "array",
      "minItems": 1,
      "maxItems": 256,
      "items": {
        "$ref": "#/$defs/PolicyLayer"
      },
      "description": "Policy layers resolved in deterministic order: org, project, task, then exceptions (priority desc, layer_id asc)."
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "allOf": [
    {
      "properties": {
        "layers": {
          "contains": {
            "type": "object",
            "required": [
              "scope"
            ],
            "properties": {
              "scope": {
                "type": "object",
                "required": [
                  "scope_type"
                ],
                "properties": {
                  "scope_type": {
                    "const": "org"
                  }
                }
              }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "PolicyLayer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "layer_id",
        "scope",
        "policy",
        "policy_hash_b64u"
      ],
      "properties": {
        "layer_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "scope": {
          "$ref": "#/$defs/PolicyScope"
        },
        "apply_mode": {
          "type": "string",
          "enum": [
            "merge",
            "replace"
          ],
          "default": "merge"
        },
        "policy": {
          "$ref": "#/$defs/LocalPolicy"
        },
        "policy_hash_b64u": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_-]+$",
          "minLength": 8
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "PolicyScope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scope_type",
        "org_id"
      ],
      "properties": {
        "scope_type": {
          "type": "string",
          "enum": [
            "org",
            "project",
            "task",
            "exception"
          ]
        },
        "org_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "project_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "task_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "exception_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "priority": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1000
        },
        "expires_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "LocalPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "statements"
      ],
      "properties": {
        "statements": {
          "type": "array",
          "minItems": 1,
          "maxItems": 256,
          "items": {
            "$ref": "#/$defs/LocalPolicyStatement"
          }
        }
      }
    },
    "LocalPolicyStatement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sid",
        "effect",
        "actions",
        "resources"
      ],
      "properties": {
        "sid": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "effect": {
          "type": "string",
          "enum": [
            "Allow",
            "Deny"
          ]
        },
        "actions": {
          "type": "array",
          "minItems": 1,
          "maxItems": 128,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256
          }
        },
        "resources": {
          "type": "array",
          "minItems": 1,
          "maxItems": 256,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 512
          }
        },
        "conditions": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1,
                "maxLength": 512
              },
              "maxItems": 64
            },
            "maxProperties": 64
          }
        }
      }
    }
  }
}
