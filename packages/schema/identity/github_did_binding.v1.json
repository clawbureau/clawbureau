{
  "$id": "https://schemas.clawbureau.org/claw.identity.github_did_binding.v1.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GitHub DID Binding Attestation Envelope v1",
  "description": "Signed attestation envelope binding a GitHub account to a DID.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "envelope_version",
    "envelope_type",
    "payload",
    "payload_hash_b64u",
    "hash_algorithm",
    "signature_b64u",
    "algorithm",
    "signer_did",
    "issued_at"
  ],
  "properties": {
    "envelope_version": { "const": "1" },
    "envelope_type": { "const": "github_did_binding" },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "attestation_version",
        "attestation_type",
        "attestation_id",
        "github_username",
        "github_user_id",
        "did",
        "statement",
        "issued_at"
      ],
      "properties": {
        "attestation_version": { "const": "1" },
        "attestation_type": { "const": "github_did_binding" },
        "attestation_id": { "type": "string", "minLength": 1 },
        "github_username": { "type": "string", "minLength": 1 },
        "github_user_id": { "type": "integer", "minimum": 1 },
        "did": {
          "type": "string",
          "pattern": "^did:"
        },
        "statement": { "type": "string", "minLength": 1 },
        "issued_at": { "type": "string", "format": "date-time" }
      }
    },
    "payload_hash_b64u": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_-]+$",
      "minLength": 8
    },
    "hash_algorithm": { "const": "SHA-256" },
    "signature_b64u": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_-]+$",
      "minLength": 8
    },
    "algorithm": { "const": "Ed25519" },
    "signer_did": {
      "type": "string",
      "pattern": "^did:"
    },
    "issued_at": { "type": "string", "format": "date-time" }
  }
}
