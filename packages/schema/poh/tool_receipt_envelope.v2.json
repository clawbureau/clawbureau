{
  "$id": "https://schemas.clawbureau.org/claw.poh.tool_receipt_envelope.v2.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Tool Receipt Envelope v2",
  "description": "Signed envelope for tool receipt v2 including additive co-signatures and optional expiry.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "envelope_version",
    "envelope_type",
    "payload",
    "payload_hash_b64u",
    "hash_algorithm",
    "signature_b64u",
    "algorithm",
    "signer_did",
    "issued_at"
  ],
  "properties": {
    "envelope_version": {
      "type": "string",
      "const": "2"
    },
    "envelope_type": {
      "type": "string",
      "const": "tool_receipt"
    },
    "payload": {
      "$ref": "https://schemas.clawbureau.org/claw.poh.tool_receipt.v2.json"
    },
    "payload_hash_b64u": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_-]+$",
      "minLength": 8
    },
    "hash_algorithm": {
      "type": "string",
      "enum": ["SHA-256", "BLAKE3"]
    },
    "signature_b64u": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_-]+$",
      "minLength": 8
    },
    "algorithm": {
      "type": "string",
      "enum": ["Ed25519"]
    },
    "signer_did": {
      "type": "string",
      "pattern": "^did:"
    },
    "issued_at": {
      "type": "string",
      "format": "date-time"
    },
    "expires_at": {
      "type": "string",
      "format": "date-time"
    },
    "co_signatures": {
      "type": "array",
      "maxItems": 16,
      "items": {
        "$ref": "https://schemas.clawbureau.org/claw.poh.co_signature.v1.json"
      }
    }
  }
}
